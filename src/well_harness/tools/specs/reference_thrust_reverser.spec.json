{
  "$schema": "https://well-harness.local/json_schema/control_system_spec_v1.schema.json",
  "acceptance_scenarios": [
    {
      "completion_condition": "deploy_position_percent == 100% and thr_lock == 1",
      "description": "将原始监控过程压缩到 1/10，作为严格验收的第一条参考场景。",
      "id": "compressed_ra_tra_vdt_monitor",
      "label": "压缩版 RA -> TRA -> VDT 监控流程",
      "monitored_signal_ids": [
        "radio_altitude_ft",
        "tra_deg",
        "sw1",
        "sw2",
        "tls_voltage_v",
        "etrac_voltage_v",
        "eec_cmd",
        "pls_cmd",
        "deploy_position_percent",
        "thr_lock"
      ],
      "steady_signals": [
        {
          "note": "参考场景固定假设发动机处于运行状态。",
          "signal_id": "engine_running",
          "unit": "state",
          "value": 1
        },
        {
          "note": "参考场景固定假设飞机已经在地面。",
          "signal_id": "aircraft_on_ground",
          "unit": "state",
          "value": 1
        },
        {
          "note": "参考场景中反推不被抑制。",
          "signal_id": "reverser_inhibited",
          "unit": "state",
          "value": 0
        },
        {
          "note": "参考场景固定假设 EEC enable 为真。",
          "signal_id": "eec_enable",
          "unit": "state",
          "value": 1
        },
        {
          "note": "参考场景中 N1K 保持在 deploy 限值以下。",
          "signal_id": "n1k",
          "unit": "percent",
          "value": 35.0
        },
        {
          "note": "参考场景中 deploy 限值固定为 60。",
          "signal_id": "max_n1k_deploy_limit",
          "unit": "percent",
          "value": 60.0
        }
      ],
      "time_scale_factor": 0.1,
      "total_duration_s": 7.0,
      "transitions": [
        {
          "end_s": 7.0,
          "end_value": 0.0,
          "note": "RA 线性下降到 0ft 后保持",
          "signal_id": "radio_altitude_ft",
          "start_s": 0.0,
          "start_value": 7.0,
          "unit": "ft"
        },
        {
          "end_s": 2.4,
          "end_value": -14.0,
          "note": "RA 降到 6ft 后，TRA 以压缩后的速率推到 -14°",
          "signal_id": "tra_deg",
          "start_s": 1.0,
          "start_value": 0.0,
          "unit": "deg"
        },
        {
          "end_s": 1.4,
          "end_value": 1.0,
          "note": "TRA 进入 SW1 窗口后，SW1 置位。",
          "signal_id": "sw1",
          "start_s": 1.2,
          "start_value": 0.0,
          "unit": "state"
        },
        {
          "end_s": 2.0,
          "end_value": 1.0,
          "note": "TRA 继续深入 reverse 区后，SW2 置位。",
          "signal_id": "sw2",
          "start_s": 1.8,
          "start_value": 0.0,
          "unit": "state"
        },
        {
          "end_s": 4.4,
          "end_value": 100.0,
          "note": "TRA 到达 -14° 后，VDT 相关反馈开始爬升到 100%",
          "signal_id": "deploy_position_percent",
          "start_s": 2.4,
          "start_value": 0.0,
          "unit": "%"
        }
      ]
    }
  ],
  "components": [
    {
      "allowed_range": [
        0.0,
        20.0
      ],
      "allowed_states": [],
      "description": "无线电高度输入；L1 依赖该值小于阈值。",
      "id": "radio_altitude_ft",
      "kind": "sensor",
      "label": "RA",
      "monitor_priority": "required",
      "state_shape": "analog",
      "unit": "ft"
    },
    {
      "allowed_range": [
        -32.0,
        0.0
      ],
      "allowed_states": [],
      "description": "反推拉杆角度；当前系统在 -32° 到 0° 之间工作。",
      "id": "tra_deg",
      "kind": "pilot_input",
      "label": "TRA",
      "monitor_priority": "required",
      "state_shape": "analog",
      "unit": "deg"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "TRA 进入 SW1 窗口时闭合。",
      "id": "sw1",
      "kind": "switch",
      "label": "SW1",
      "monitor_priority": "required",
      "state_shape": "binary",
      "unit": "state"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "TRA 进入 SW2 窗口时闭合。",
      "id": "sw2",
      "kind": "switch",
      "label": "SW2",
      "monitor_priority": "required",
      "state_shape": "binary",
      "unit": "state"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "发动机运行状态；L2/L4 依赖该值为真。",
      "id": "engine_running",
      "kind": "state",
      "label": "Engine Running",
      "monitor_priority": "optional",
      "state_shape": "binary",
      "unit": "state"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "飞机是否在地面；L2/L4 依赖该值为真。",
      "id": "aircraft_on_ground",
      "kind": "state",
      "label": "On Ground",
      "monitor_priority": "optional",
      "state_shape": "binary",
      "unit": "state"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "反推抑制状态；L1/L2 依赖该值为假。",
      "id": "reverser_inhibited",
      "kind": "state",
      "label": "Reverser Inhibited",
      "monitor_priority": "optional",
      "state_shape": "binary",
      "unit": "state"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "EEC 允许位；L2 依赖该值为真。",
      "id": "eec_enable",
      "kind": "state",
      "label": "EEC Enable",
      "monitor_priority": "optional",
      "state_shape": "binary",
      "unit": "state"
    },
    {
      "allowed_range": [
        0.0,
        110.0
      ],
      "allowed_states": [],
      "description": "N1K 输入；L3 依赖该值低于限制。",
      "id": "n1k",
      "kind": "sensor",
      "label": "N1K",
      "monitor_priority": "optional",
      "state_shape": "analog",
      "unit": "percent"
    },
    {
      "allowed_range": [
        0.0,
        110.0
      ],
      "allowed_states": [],
      "description": "允许 deploy 的 N1K 限制。",
      "id": "max_n1k_deploy_limit",
      "kind": "parameter",
      "label": "Max N1K Deploy Limit",
      "monitor_priority": "optional",
      "state_shape": "analog",
      "unit": "percent"
    },
    {
      "allowed_range": [
        0.0,
        115.0
      ],
      "allowed_states": [],
      "description": "TLS 组件断开时为 0V，接通后为 115V。",
      "id": "tls_voltage_v",
      "kind": "power",
      "label": "TLS",
      "monitor_priority": "required",
      "state_shape": "analog",
      "unit": "V"
    },
    {
      "allowed_range": [
        0.0,
        540.0
      ],
      "allowed_states": [],
      "description": "ETRAC 组件断开时为 0V，接通后为 540V。",
      "id": "etrac_voltage_v",
      "kind": "power",
      "label": "ETRAC",
      "monitor_priority": "required",
      "state_shape": "analog",
      "unit": "V"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "EEC 指令节点，只有 0/1 状态。",
      "id": "eec_cmd",
      "kind": "command",
      "label": "EEC",
      "monitor_priority": "required",
      "state_shape": "binary",
      "unit": "state"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "PLS 指令节点，只有 0/1 状态。",
      "id": "pls_cmd",
      "kind": "command",
      "label": "PLS",
      "monitor_priority": "required",
      "state_shape": "binary",
      "unit": "state"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "PDU 驱动命令，当前逻辑由 L3 扇出。",
      "id": "pdu_cmd",
      "kind": "command",
      "label": "PDU",
      "monitor_priority": "optional",
      "state_shape": "binary",
      "unit": "state"
    },
    {
      "allowed_range": [
        0.0,
        100.0
      ],
      "allowed_states": [],
      "description": "当前参考系统中的 simplified plant 位移反馈，用于产生 VDT90/L4 条件。",
      "id": "deploy_position_percent",
      "kind": "feedback",
      "label": "Deploy Feedback",
      "monitor_priority": "required",
      "state_shape": "analog",
      "unit": "%"
    },
    {
      "allowed_range": null,
      "allowed_states": [
        "0",
        "1"
      ],
      "description": "电子油门锁释放命令，只有 0/1 状态。",
      "id": "thr_lock",
      "kind": "command",
      "label": "THR_LOCK",
      "monitor_priority": "required",
      "state_shape": "binary",
      "unit": "state"
    }
  ],
  "fault_modes": [
    {
      "expected_diagnostic_sections": [
        "symptoms",
        "upstream_checks",
        "logic_blockers",
        "repair_hint"
      ],
      "fault_kind": "stuck_low",
      "id": "sw1_stuck_open",
      "optimization_prompt": "如果 SW1 失效频繁，可评估是否增加独立的 travel cross-check 或更明确的锁位自检。",
      "reasoning_scope_component_ids": [
        "radio_altitude_ft",
        "sw1",
        "logic1",
        "tls_voltage_v"
      ],
      "symptom": "RA 已低于阈值但 TLS 始终不通电。",
      "target_component_id": "sw1"
    },
    {
      "expected_diagnostic_sections": [
        "symptoms",
        "power_path",
        "unlock_assumptions",
        "repair_hint"
      ],
      "fault_kind": "latched_no_unlock",
      "id": "tls_never_unlocks",
      "optimization_prompt": "可评估增加 TLS 解锁状态确认或超时降级提示，降低下游诊断歧义。",
      "reasoning_scope_component_ids": [
        "logic1",
        "tls_voltage_v",
        "logic3",
        "eec_cmd",
        "pls_cmd"
      ],
      "symptom": "TLS 已通电但 L3 长时间不满足，EEC/PLS/PDU 不扇出。",
      "target_component_id": "tls_voltage_v"
    },
    {
      "expected_diagnostic_sections": [
        "symptoms",
        "boundary_checks",
        "downstream_command_path",
        "repair_hint"
      ],
      "fault_kind": "command_path_failure",
      "id": "thr_lock_never_releases",
      "optimization_prompt": "可评估将 L4 条件和 THR_LOCK 执行链分开观测，提升容错和可诊断性。",
      "reasoning_scope_component_ids": [
        "deploy_position_percent",
        "logic4",
        "thr_lock"
      ],
      "symptom": "TRA 和反馈位移都已满足，但 THR_LOCK 仍未释放。",
      "target_component_id": "thr_lock"
    }
  ],
  "kind": "well-harness-control-system-spec",
  "knowledge_capture": {
    "incident_fields": [
      "system_id",
      "scenario_id",
      "fault_mode_id",
      "observed_symptoms",
      "evidence_links"
    ],
    "optimization_fields": [
      "suggested_logic_change",
      "reliability_gain_hypothesis",
      "redundancy_reduction_or_guardrail_note"
    ],
    "resolution_fields": [
      "confirmed_root_cause",
      "repair_action",
      "validation_after_fix",
      "residual_risk"
    ]
  },
  "logic_nodes": [
    {
      "conditions": [
        {
          "comparison": "<",
          "name": "radio_altitude_ft",
          "note": "RA 需要低于阈值",
          "source_component_id": "radio_altitude_ft",
          "threshold_value": 6.0
        },
        {
          "comparison": "==",
          "name": "sw1",
          "note": "SW1 必须闭合",
          "source_component_id": "sw1",
          "threshold_value": true
        },
        {
          "comparison": "==",
          "name": "reverser_inhibited",
          "note": "反推不能被抑制",
          "source_component_id": "reverser_inhibited",
          "threshold_value": false
        },
        {
          "comparison": "==",
          "name": "reverser_not_deployed_eec",
          "note": "EEC 视角下应仍处于未展开",
          "source_component_id": "reverser_not_deployed_eec",
          "threshold_value": true
        }
      ],
      "description": "RA + SW1 + inhibit/eec 边界共同驱动 TLS。",
      "downstream_component_ids": [
        "tls_voltage_v"
      ],
      "evidence_priority": "high",
      "id": "logic1",
      "label": "L1"
    },
    {
      "conditions": [
        {
          "comparison": "==",
          "name": "engine_running",
          "note": "发动机必须运行",
          "source_component_id": "engine_running",
          "threshold_value": true
        },
        {
          "comparison": "==",
          "name": "aircraft_on_ground",
          "note": "飞机必须在地面",
          "source_component_id": "aircraft_on_ground",
          "threshold_value": true
        },
        {
          "comparison": "==",
          "name": "reverser_inhibited",
          "note": "反推不能被抑制",
          "source_component_id": "reverser_inhibited",
          "threshold_value": false
        },
        {
          "comparison": "==",
          "name": "sw2",
          "note": "SW2 必须闭合",
          "source_component_id": "sw2",
          "threshold_value": true
        },
        {
          "comparison": "<=",
          "name": "sw2_hysteresis_tra_deg",
          "note": "TRA 必须低于 SW2 hysteresis 阈值（PROP-20260426T075902988411-e27a6e: tighten L2 SW2 dependency）",
          "source_component_id": "tra_deg",
          "threshold_value": -5.5
        },
        {
          "comparison": "==",
          "name": "eec_enable",
          "note": "EEC enable 必须为真",
          "source_component_id": "eec_enable",
          "threshold_value": true
        }
      ],
      "description": "发动机/地面/SW2/EEC 边界共同驱动 ETRAC（PROP-20260426T075902988411-e27a6e: 增加 SW2 TRA hysteresis 收紧条件）。",
      "downstream_component_ids": [
        "etrac_voltage_v"
      ],
      "evidence_priority": "high",
      "id": "logic2",
      "label": "L2"
    },
    {
      "conditions": [
        {
          "comparison": "==",
          "name": "engine_running",
          "note": "发动机必须运行",
          "source_component_id": "engine_running",
          "threshold_value": true
        },
        {
          "comparison": "==",
          "name": "aircraft_on_ground",
          "note": "飞机必须在地面",
          "source_component_id": "aircraft_on_ground",
          "threshold_value": true
        },
        {
          "comparison": "==",
          "name": "reverser_inhibited",
          "note": "反推不能被抑制",
          "source_component_id": "reverser_inhibited",
          "threshold_value": false
        },
        {
          "comparison": "==",
          "name": "tls_unlocked_ls",
          "note": "TLS 已通电并经过解锁延迟",
          "source_component_id": "tls_unlocked_ls",
          "threshold_value": true
        },
        {
          "comparison": "<",
          "name": "n1k",
          "note": "N1K 必须低于 limit",
          "source_component_id": "n1k",
          "threshold_value": "max_n1k_deploy_limit"
        },
        {
          "comparison": "<=",
          "name": "tra_deg",
          "note": "TRA 必须进入 L3 阈值内",
          "source_component_id": "tra_deg",
          "threshold_value": -11.74
        }
      ],
      "description": "TLS 解锁、N1K、TRA 阈值共同驱动 EEC / PLS / PDU。",
      "downstream_component_ids": [
        "eec_cmd",
        "pls_cmd",
        "pdu_cmd"
      ],
      "evidence_priority": "high",
      "id": "logic3",
      "label": "L3"
    },
    {
      "conditions": [
        {
          "comparison": ">=",
          "name": "deploy_90_percent_vdt",
          "note": "VDT 反馈位移已达到 90%（由 L3 驱动 PDU 产生）",
          "source_component_id": "deploy_position_percent",
          "threshold_value": 90.0
        },
        {
          "comparison": "between_lower_inclusive",
          "name": "tra_deg",
          "note": "TRA 必须处于有效反推 travel 内（下界包含：机械停位即最大反推，仍有效）",
          "source_component_id": "tra_deg",
          "threshold_value": [
            -32.0,
            0.0
          ]
        },
        {
          "comparison": "==",
          "name": "aircraft_on_ground",
          "note": "飞机必须在地面",
          "source_component_id": "aircraft_on_ground",
          "threshold_value": true
        },
        {
          "comparison": "==",
          "name": "engine_running",
          "note": "发动机必须运行",
          "source_component_id": "engine_running",
          "threshold_value": true
        }
      ],
      "description": "VDT90、反推 travel、发动机和地面条件共同驱动 THR_LOCK。注意：VDT90 由 L3 扇出的 PDU motor 驱动位移反馈产生，L4 实际上间接依赖 L3 的成立（物理因果链：L3 → pdu_motor_cmd → deploy_position_percent ≥ 90% → VDT90 → L4）。",
      "downstream_component_ids": [
        "thr_lock"
      ],
      "evidence_priority": "high",
      "id": "logic4",
      "label": "L4"
    }
  ],
  "objective": "Use the current deterministic deploy chain as the first reference system for future strict acceptance playback, fault injection, diagnosis, and cross-system generalization.",
  "onboarding_questions": [
    {
      "id": "source_documents",
      "prompt": "新系统的输入文档具体是什么格式：结构化表格、Markdown/Notion、PDF，还是混合来源？",
      "rationale": "决定是否先做文档适配器，还是先要求工程师整理为统一 spec。",
      "required_for": "严格验收与快速泛化"
    },
    {
      "id": "component_state_domains",
      "prompt": "每个组件究竟是二值开关、固定电平、离散状态，还是连续模拟量？单位和合法范围分别是什么？",
      "rationale": "避免把不同信号形态混成一套错误的监控曲线。",
      "required_for": "监控曲线仿真与故障注入"
    },
    {
      "id": "timeline_rules",
      "prompt": "工程师给出的运行过程是事件驱动、速率驱动，还是带延时/滞后的状态机？哪些节点允许保持/饱和？",
      "rationale": "决定如何把 A/B 过程文档转成严格可回放的时间线。",
      "required_for": "严格验收仿真"
    },
    {
      "id": "fault_taxonomy",
      "prompt": "新系统需要支持哪些故障注入类型：卡滞、短路、断路、虚警、延迟、阈值漂移，还是其他类型？",
      "rationale": "决定诊断树、推理文档模板和优化建议的范围。",
      "required_for": "故障分析与知识积累"
    }
  ],

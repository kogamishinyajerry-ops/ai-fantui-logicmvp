{
  "asset_name": "well_harness.validation_schema_runner_report.v1",
  "command": [
    "--format",
    "json"
  ],
  "required_top_level_fields": [
    "status",
    "schema_path",
    "asset_path",
    "results"
  ],
  "schema_path": "docs/json_schema/validation_report_v1.schema.json",
  "asset_path": "tests/fixtures/validation_report_asset_v1.json",
  "required_result_fields": [
    "scenario",
    "report_status",
    "validation_status",
    "report_exit_code"
  ],
  "pass": {
    "expected_status": "pass",
    "expected_result_count": 5,
    "expected_validation_status": "pass",
    "expected_scenarios": [
      "pass",
      "skip",
      "fail_cli",
      "fail_schema_unavailable",
      "fail_schema_validation"
    ],
    "expected_scenario_report_statuses": {
      "pass": "pass",
      "skip": "skip",
      "fail_cli": "fail",
      "fail_schema_unavailable": "fail",
      "fail_schema_validation": "fail"
    }
  },
  "skip": {
    "env": {
      "WELL_HARNESS_FORCE_JSONSCHEMA_MISSING": "1"
    },
    "expected_status": "skip",
    "expected_result_count": 0,
    "expected_reason_contains": "optional dependency 'jsonschema' is not installed"
  },
  "fail": {
    "env": {
      "WELL_HARNESS_FORCE_SCHEMA_PATH": "tests/fixtures/_missing_validation_schema_runner_schema_for_asset.json"
    },
    "expected_status": "fail",
    "expected_failure_kind": "status_mismatch",
    "expected_result_count": 1,
    "expected_result_fields": {
      "scenario": "pass",
      "report_status": "fail",
      "validation_status": "fail",
      "expected_report_status": "pass",
      "report_exit_code": 1
    }
  }
}

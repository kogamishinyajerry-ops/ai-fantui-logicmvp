{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://well-harness.local/json_schema/hardware_evidence_report_v1.schema.json",
  "title": "well_harness.hardware_evidence_report v1",
  "description": "Read-only hardware evidence report for LRU/signal coverage and evidence-gap accounting. This report is audit metadata only and does not promote truth level, assign DAL/PSSA, or alter controller behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "generated_by",
    "adapter",
    "layer",
    "truth_level_impact",
    "status",
    "hardware_summary",
    "coverage",
    "evidence_gaps",
    "evidence_index",
    "boundaries",
    "checks"
  ],
  "properties": {
    "$schema": {
      "const": "https://well-harness.local/json_schema/hardware_evidence_report_v1.schema.json"
    },
    "schema_version": {
      "const": "hardware_evidence_report.v1"
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "adapter": {
      "const": "thrust-reverser"
    },
    "layer": {
      "const": "L6"
    },
    "truth_level_impact": {
      "const": "none"
    },
    "status": {
      "enum": ["pass", "fail"]
    },
    "hardware_summary": {
      "$ref": "#/$defs/hardwareSummary"
    },
    "coverage": {
      "$ref": "#/$defs/coverage"
    },
    "evidence_gaps": {
      "$ref": "#/$defs/evidenceGaps"
    },
    "evidence_index": {
      "$ref": "#/$defs/evidenceIndex"
    },
    "boundaries": {
      "$ref": "#/$defs/boundaries"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    }
  },
  "$defs": {
    "pathList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hardwareSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_id",
        "kind",
        "version",
        "hardware_path",
        "read_only",
        "truth_level_impact",
        "dal_pssa_impact",
        "controller_truth_source",
        "controller_truth_modified",
        "lru_count",
        "signal_binding_count",
        "lru_evidence_gap_field_count",
        "signal_evidence_gap_field_count",
        "total_evidence_gap_field_count",
        "inferred_field_count",
        "frozen_hardware_paths",
        "read_protected_hardware_paths"
      ],
      "properties": {
        "system_id": {
          "const": "thrust-reverser"
        },
        "kind": {
          "const": "thrust-reverser-hardware"
        },
        "version": {
          "const": 1
        },
        "hardware_path": {
          "const": "config/hardware/thrust_reverser_hardware_v1.yaml"
        },
        "read_only": {
          "const": true
        },
        "truth_level_impact": {
          "const": "none"
        },
        "dal_pssa_impact": {
          "const": "none"
        },
        "controller_truth_source": {
          "const": "src/well_harness/controller.py"
        },
        "controller_truth_modified": {
          "const": false
        },
        "lru_count": {
          "type": "integer",
          "minimum": 0
        },
        "signal_binding_count": {
          "type": "integer",
          "minimum": 0
        },
        "lru_evidence_gap_field_count": {
          "type": "integer",
          "minimum": 0
        },
        "signal_evidence_gap_field_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_evidence_gap_field_count": {
          "type": "integer",
          "minimum": 0
        },
        "inferred_field_count": {
          "const": 0
        },
        "frozen_hardware_paths": {
          "$ref": "#/$defs/pathList"
        },
        "read_protected_hardware_paths": {
          "$ref": "#/$defs/pathList"
        }
      }
    },
    "coverageCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "expected_count", "actual_count"],
      "properties": {
        "status": {
          "enum": ["pass", "fail"]
        },
        "expected_count": {
          "type": "integer",
          "minimum": 0
        },
        "actual_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lru_inventory", "signal_bindings"],
      "properties": {
        "lru_inventory": {
          "$ref": "#/$defs/coverageCheck"
        },
        "signal_bindings": {
          "$ref": "#/$defs/coverageCheck"
        }
      }
    },
    "evidenceGaps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lru_field_count",
        "signal_field_count",
        "total_field_count",
        "inferred_field_count"
      ],
      "properties": {
        "lru_field_count": {
          "type": "integer",
          "minimum": 0
        },
        "signal_field_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_field_count": {
          "type": "integer",
          "minimum": 0
        },
        "inferred_field_count": {
          "const": 0
        }
      }
    },
    "valueRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "value"],
      "properties": {
        "status": {
          "enum": ["known", "evidence_gap"]
        },
        "value": {
          "type": "string"
        }
      }
    },
    "lruInventoryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_name",
        "value_status",
        "source_ref",
        "truth_effect"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "value_status": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "truth_effect": {
          "const": "none"
        }
      }
    },
    "signalBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "direction",
        "source_hardware_id",
        "peer_hardware_id",
        "cable",
        "connector",
        "port_local",
        "port_peer",
        "redundancy_status",
        "evidence_status",
        "feeds_logic_nodes",
        "source_ref",
        "carrier_status",
        "display_status",
        "truth_effect"
      ],
      "properties": {
        "signal_id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "minLength": 1
        },
        "source_hardware_id": {
          "type": "string",
          "minLength": 1
        },
        "peer_hardware_id": {
          "type": "string",
          "minLength": 1
        },
        "cable": {
          "$ref": "#/$defs/valueRef"
        },
        "connector": {
          "$ref": "#/$defs/valueRef"
        },
        "port_local": {
          "$ref": "#/$defs/valueRef"
        },
        "port_peer": {
          "$ref": "#/$defs/valueRef"
        },
        "redundancy_status": {
          "type": "string",
          "minLength": 1
        },
        "evidence_status": {
          "type": "string",
          "minLength": 1
        },
        "feeds_logic_nodes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^L[1-4]$"
          }
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "carrier_status": {
          "enum": ["recorded", "evidence_gap"]
        },
        "display_status": {
          "enum": ["recorded", "not_recorded"]
        },
        "truth_effect": {
          "const": "none"
        }
      }
    },
    "logicNodeBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["L1", "L2", "L3", "L4"],
      "properties": {
        "L1": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signalBinding"
          }
        },
        "L2": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signalBinding"
          }
        },
        "L3": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signalBinding"
          }
        },
        "L4": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signalBinding"
          }
        }
      }
    },
    "evidenceIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "truth_effect",
        "read_only",
        "lru_inventory_count",
        "signal_binding_count",
        "evidence_gap_count",
        "lru_inventory",
        "signal_bindings",
        "logic_node_bindings"
      ],
      "properties": {
        "truth_effect": {
          "const": "none"
        },
        "read_only": {
          "const": true
        },
        "lru_inventory_count": {
          "type": "integer",
          "minimum": 0
        },
        "signal_binding_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_gap_count": {
          "type": "integer",
          "minimum": 0
        },
        "lru_inventory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lruInventoryItem"
          }
        },
        "signal_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/signalBinding"
          }
        },
        "logic_node_bindings": {
          "$ref": "#/$defs/logicNodeBindings"
        }
      }
    },
    "boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "controller_truth_modified",
        "truth_level_impact",
        "dal_pssa_impact",
        "frozen_hardware_paths"
      ],
      "properties": {
        "read_only": {
          "const": true
        },
        "controller_truth_modified": {
          "const": false
        },
        "truth_level_impact": {
          "const": "none"
        },
        "dal_pssa_impact": {
          "const": "none"
        },
        "frozen_hardware_paths": {
          "$ref": "#/$defs/pathList"
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["pass", "fail"]
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://well-harness.local/json_schema/hardware_schema_v1.schema.json",
  "title": "well_harness.thrust_reverser_hardware v1",
  "description": "JSON Schema for thrust-reverser hardware parameter YAML files. Validates that hardware parameter files conform to the expected structure and value ranges.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "system_id",
    "parameters"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "thrust-reverser-hardware"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "system_id": {
      "type": "string",
      "minLength": 1
    },
    "lru_inventory": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lruInventoryItem"
      }
    },
    "signal_carrier_bindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signalCarrierBinding"
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sensor",
        "actuator",
        "logic_thresholds",
        "timing",
        "physical_limits"
      ],
      "properties": {
        "sensor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "radio_altitude_ft": {
              "type": "object",
              "additionalProperties": false,
              "required": ["unit", "typical_range_ft", "accuracy_ft"],
              "properties": {
                "unit": {
                  "type": "string",
                  "const": "ft"
                },
                "typical_range_ft": {
                  "type": "number",
                  "minimum": 0
                },
                "accuracy_ft": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        },
        "actuator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tra", "vd"],
          "properties": {
            "tra": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "unit",
                "min_deg",
                "max_deg",
                "nominal_deployment_rate_percent_per_s"
              ],
              "properties": {
                "unit": {
                  "type": "string",
                  "const": "deg"
                },
                "min_deg": {
                  "type": "number"
                },
                "max_deg": {
                  "type": "number"
                },
                "nominal_deployment_rate_percent_per_s": {
                  "type": "number",
                  "minimum": 0
                }
              }
            },
            "vd": {
              "type": "object",
              "additionalProperties": false,
              "required": ["unit", "full_deploy_percent"],
              "properties": {
                "unit": {
                  "type": "string",
                  "const": "percent"
                },
                "full_deploy_percent": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                }
              }
            }
          }
        },
        "logic_thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "logic1_ra_ft_threshold",
            "logic3_tra_deg_threshold",
            "deploy_90_threshold_percent"
          ],
          "properties": {
            "logic1_ra_ft_threshold": {
              "type": "number",
              "minimum": 0
            },
            "logic3_tra_deg_threshold": {
              "type": "number"
            },
            "deploy_90_threshold_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        },
        "timing": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tls_unlock_delay_s", "pls_unlock_delay_s"],
          "properties": {
            "tls_unlock_delay_s": {
              "type": "number",
              "minimum": 0
            },
            "pls_unlock_delay_s": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "physical_limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reverse_travel_min_deg",
            "reverse_travel_max_deg",
            "sw1_window",
            "sw2_window"
          ],
          "properties": {
            "reverse_travel_min_deg": {
              "type": "number"
            },
            "reverse_travel_max_deg": {
              "type": "number"
            },
            "sw1_window": {
              "type": "object",
              "additionalProperties": false,
              "required": ["near_zero_deg", "deep_reverse_deg"],
              "properties": {
                "near_zero_deg": {
                  "type": "number"
                },
                "deep_reverse_deg": {
                  "type": "number"
                }
              }
            },
            "sw2_window": {
              "type": "object",
              "additionalProperties": false,
              "required": ["near_zero_deg", "deep_reverse_deg"],
              "properties": {
                "near_zero_deg": {
                  "type": "number"
                },
                "deep_reverse_deg": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "valueStatus": {
      "type": "string",
      "enum": [
        "confirmed",
        "evidence_gap",
        "not_applicable"
      ]
    },
    "valueRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "value"
      ],
      "properties": {
        "status": {
          "$ref": "#/$defs/valueStatus"
        },
        "value": {
          "type": [
            "string",
            "number",
            "integer",
            "null"
          ]
        }
      }
    },
    "lruInventoryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_name",
        "quantity_per_engine",
        "value_status",
        "part_number",
        "location",
        "failure_rate_per_hour",
        "source_ref"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "quantity_per_engine": {
          "type": [
            "number",
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "value_status": {
          "$ref": "#/$defs/valueStatus"
        },
        "part_number": {
          "$ref": "#/$defs/valueRef"
        },
        "location": {
          "$ref": "#/$defs/valueRef"
        },
        "failure_rate_per_hour": {
          "$ref": "#/$defs/valueRef"
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "signalCarrierBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal_id",
        "direction",
        "source_hardware_id",
        "peer_hardware_id",
        "cable",
        "connector",
        "port_local",
        "port_peer",
        "redundancy_status",
        "evidence_status",
        "feeds_logic_nodes",
        "source_ref"
      ],
      "properties": {
        "signal_id": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "enum": [
            "input",
            "feedback",
            "output"
          ]
        },
        "source_hardware_id": {
          "type": "string",
          "minLength": 1
        },
        "peer_hardware_id": {
          "type": "string",
          "minLength": 1
        },
        "cable": {
          "$ref": "#/$defs/valueRef"
        },
        "connector": {
          "$ref": "#/$defs/valueRef"
        },
        "port_local": {
          "$ref": "#/$defs/valueRef"
        },
        "port_peer": {
          "$ref": "#/$defs/valueRef"
        },
        "redundancy_status": {
          "type": "string",
          "enum": [
            "single",
            "dual",
            "multiple",
            "not_applicable",
            "evidence_gap"
          ]
        },
        "evidence_status": {
          "$ref": "#/$defs/valueStatus"
        },
        "feeds_logic_nodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

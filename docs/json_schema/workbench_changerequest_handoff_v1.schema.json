{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://well-harness.local/json_schema/workbench_changerequest_handoff_v1.schema.json",
  "title": "well_harness.workbench_changerequest_handoff v1 JSON payload",
  "description": "Sandbox-only ChangeRequest handoff packet generated by /workbench. It prepares review evidence and never mutates Linear, controller truth, frozen assets, DAL, PSSA, or truth level.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "kind",
    "version",
    "packet_state",
    "candidate_state",
    "certification_claim",
    "truth_effect",
    "live_linear_mutation",
    "controller_truth_modified",
    "frozen_assets_modified",
    "truth_level_impact",
    "dal_pssa_impact",
    "red_lines_touched",
    "artifact_scope",
    "truth_scope",
    "runtime_mutates_truth",
    "serialization",
    "outcome",
    "context",
    "acceptance",
    "boundaries",
    "evidence_required",
    "red_line_metadata",
    "metadata",
    "artifacts",
    "linear_issue_body",
    "pr_proof_packet",
    "changerequest_proof_packet"
  ],
  "properties": {
    "$schema": {
      "const": "https://well-harness.local/json_schema/workbench_changerequest_handoff_v1.schema.json"
    },
    "kind": {
      "const": "well-harness-workbench-changerequest-handoff-packet"
    },
    "version": {
      "const": 1
    },
    "packet_state": {
      "const": "draft"
    },
    "candidate_state": {
      "const": "sandbox_candidate"
    },
    "certification_claim": {
      "const": "none"
    },
    "truth_effect": {
      "const": "none"
    },
    "live_linear_mutation": {
      "const": false
    },
    "controller_truth_modified": {
      "const": false
    },
    "frozen_assets_modified": {
      "const": false
    },
    "truth_level_impact": {
      "const": "none"
    },
    "dal_pssa_impact": {
      "const": "none"
    },
    "red_lines_touched": {
      "const": "none"
    },
    "artifact_scope": {
      "const": "browser_local_draft"
    },
    "truth_scope": {
      "const": "evidence_only"
    },
    "runtime_mutates_truth": {
      "const": false
    },
    "serialization": {
      "$ref": "#/$defs/serialization"
    },
    "outcome": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "context": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "acceptance": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "boundaries": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "evidence_required": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "red_line_metadata": {
      "$ref": "#/$defs/redLineMetadata"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "linear_issue_body": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "pr_proof_packet": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "changerequest_proof_packet": {
      "$ref": "#/$defs/changerequestProofPacket"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "serialization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalization",
        "checksum_algorithm"
      ],
      "properties": {
        "canonicalization": {
          "const": "json.sort_keys.separators.v1"
        },
        "checksum_algorithm": {
          "const": "ui_fnv1a32_over_canonical_json"
        }
      }
    },
    "redLineMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "red_lines_touched",
        "truth_level_impact",
        "dal_pssa_impact",
        "controller_truth_modified",
        "frozen_assets_modified",
        "live_linear_mutation"
      ],
      "properties": {
        "red_lines_touched": {
          "const": "none"
        },
        "truth_level_impact": {
          "const": "none"
        },
        "dal_pssa_impact": {
          "const": "none"
        },
        "controller_truth_modified": {
          "const": false
        },
        "frozen_assets_modified": {
          "const": false
        },
        "live_linear_mutation": {
          "const": false
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linear_issue",
        "linear_project",
        "adapter",
        "layer",
        "selected_scenario_id",
        "selected_node_id",
        "changed_model_hash",
        "sandbox_verdict",
        "diff_review_v2",
        "test_delta",
        "agent_eligible"
      ],
      "properties": {
        "linear_issue": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "linear_project": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "adapter": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "layer": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "selected_scenario_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "selected_node_id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "changed_model_hash": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "sandbox_verdict": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "diff_review_v2": {
          "type": "object"
        },
        "test_delta": {
          "$ref": "#/$defs/testDelta"
        },
        "agent_eligible": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "testDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targeted_pytest",
        "default_pytest",
        "gsd_validation_suite",
        "adversarial_8_8",
        "e2e_49_49",
        "mypy_strict_clean",
        "truth_effect"
      ],
      "properties": {
        "targeted_pytest": {
          "$ref": "#/$defs/gateStatus"
        },
        "default_pytest": {
          "$ref": "#/$defs/gateStatus"
        },
        "gsd_validation_suite": {
          "$ref": "#/$defs/gateStatus"
        },
        "adversarial_8_8": {
          "$ref": "#/$defs/gateStatus"
        },
        "e2e_49_49": {
          "const": "not_claimed"
        },
        "mypy_strict_clean": {
          "const": "not_claimed"
        },
        "truth_effect": {
          "const": "none"
        }
      }
    },
    "gateStatus": {
      "enum": [
        "pending",
        "pass",
        "fail",
        "blocked",
        "not_run",
        "not_claimed"
      ]
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linear_issue_body_checksum",
        "pr_proof_packet_checksum",
        "changerequest_proof_packet_checksum",
        "diff_review_v2_checksum"
      ],
      "properties": {
        "linear_issue_body_checksum": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "pr_proof_packet_checksum": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "changerequest_proof_packet_checksum": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "diff_review_v2_checksum": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "changerequestProofPacket": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "candidate_state",
        "certification_claim",
        "truth_level_impact",
        "dal_pssa_impact",
        "red_lines_touched",
        "controller_truth_modified",
        "frozen_assets_modified",
        "truth_effect",
        "linear"
      ],
      "properties": {
        "candidate_state": {
          "const": "sandbox_candidate"
        },
        "certification_claim": {
          "const": "none"
        },
        "truth_level_impact": {
          "const": "none"
        },
        "dal_pssa_impact": {
          "const": "none"
        },
        "red_lines_touched": {
          "const": "none"
        },
        "controller_truth_modified": {
          "const": false
        },
        "frozen_assets_modified": {
          "const": false
        },
        "truth_effect": {
          "const": "none"
        },
        "linear": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "live_mutation"
          ],
          "properties": {
            "live_mutation": {
              "const": false
            }
          }
        }
      }
    }
  }
}

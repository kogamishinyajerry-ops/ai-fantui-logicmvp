{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://well-harness.local/json_schema/validation_report_v1.schema.json",
  "title": "well_harness validation report v1",
  "description": "Machine-readable structure reference for tools/validate_debug_json_schema.py --format json.",
  "type": "object",
  "x-well-harness-validation-report": {
    "schema_name": "well_harness.validation_report",
    "schema_version": "1.0",
    "top_level_fields": [
      "status",
      "schema_path",
      "results"
    ],
    "result_fields": [
      "contract_name",
      "contract_path",
      "scenario_name",
      "view",
      "status"
    ],
    "report_statuses": [
      "pass",
      "skip",
      "fail"
    ],
    "result_statuses": [
      "pass",
      "fail"
    ],
    "failure_kinds": [
      "schema_unavailable",
      "cli_exit",
      "schema_validation"
    ]
  },
  "oneOf": [
    {
      "$ref": "#/$defs/passReport"
    },
    {
      "$ref": "#/$defs/skipReport"
    },
    {
      "$ref": "#/$defs/failReport"
    }
  ],
  "$defs": {
    "reportBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "schema_path",
        "results"
      ],
      "properties": {
        "status": {
          "enum": [
            "pass",
            "skip",
            "fail"
          ]
        },
        "schema_path": {
          "type": "string"
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reportResult"
          }
        },
        "failure_kind": {
          "$ref": "#/$defs/failureKind"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "resultBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_name",
        "contract_path",
        "scenario_name",
        "view",
        "status"
      ],
      "properties": {
        "contract_name": {
          "type": "string"
        },
        "contract_path": {
          "type": "string"
        },
        "scenario_name": {
          "type": "string"
        },
        "view": {
          "type": "string"
        },
        "status": {
          "enum": [
            "pass",
            "fail"
          ]
        },
        "failure_kind": {
          "enum": [
            "cli_exit",
            "schema_validation"
          ]
        },
        "exit_code": {
          "type": "integer"
        },
        "detail": {
          "type": "string"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "passResult": {
      "allOf": [
        {
          "$ref": "#/$defs/resultBase"
        },
        {
          "properties": {
            "status": {
              "const": "pass"
            }
          }
        }
      ]
    },
    "failResult": {
      "allOf": [
        {
          "$ref": "#/$defs/resultBase"
        },
        {
          "properties": {
            "status": {
              "const": "fail"
            }
          }
        }
      ]
    },
    "reportResult": {
      "oneOf": [
        {
          "$ref": "#/$defs/passResult"
        },
        {
          "$ref": "#/$defs/failResult"
        }
      ]
    },
    "failureKind": {
      "enum": [
        "schema_unavailable",
        "cli_exit",
        "schema_validation"
      ]
    },
    "passReport": {
      "allOf": [
        {
          "$ref": "#/$defs/reportBase"
        },
        {
          "properties": {
            "status": {
              "const": "pass"
            },
            "results": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/passResult"
              }
            }
          }
        }
      ]
    },
    "skipReport": {
      "allOf": [
        {
          "$ref": "#/$defs/reportBase"
        },
        {
          "required": [
            "reason"
          ],
          "properties": {
            "status": {
              "const": "skip"
            },
            "results": {
              "type": "array",
              "maxItems": 0
            },
            "reason": {
              "type": "string"
            }
          }
        }
      ]
    },
    "failReport": {
      "allOf": [
        {
          "$ref": "#/$defs/reportBase"
        },
        {
          "required": [
            "failure_kind"
          ],
          "properties": {
            "status": {
              "const": "fail"
            },
            "failure_kind": {
              "$ref": "#/$defs/failureKind"
            },
            "reason": {
              "type": "string"
            },
            "results": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/failResult"
              }
            }
          }
        }
      ]
    }
  }
}

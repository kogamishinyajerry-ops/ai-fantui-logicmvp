{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://well-harness.local/json_schema/playback_trace_v1.schema.json",
  "title": "well_harness.playback_trace v1 JSON payload",
  "description": "System-agnostic machine-readable schema for deterministic control-system playback traces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "kind",
    "version",
    "system_id",
    "system_title",
    "scenario_id",
    "scenario_label",
    "sample_period_s",
    "total_duration_s",
    "time_scale_factor",
    "completion_condition",
    "completion_reached",
    "assumptions",
    "signal_series",
    "logic_series",
    "events"
  ],
  "properties": {
    "$schema": {
      "const": "https://well-harness.local/json_schema/playback_trace_v1.schema.json"
    },
    "kind": {
      "const": "well-harness-playback-trace"
    },
    "version": {
      "const": 1
    },
    "system_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "system_title": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "scenario_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "scenario_label": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "sample_period_s": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "total_duration_s": {
      "type": "number",
      "minimum": 0
    },
    "time_scale_factor": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "completion_condition": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "completion_reached": {
      "type": "boolean"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "signal_series": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/playbackSeries"
      }
    },
    "logic_series": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/playbackSeries"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/playbackEvent"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "playbackPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_s",
        "value"
      ],
      "properties": {
        "time_s": {
          "type": "number",
          "minimum": 0
        },
        "value": {
          "type": "number"
        }
      }
    },
    "playbackSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind",
        "unit",
        "source",
        "points"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "unit": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/playbackPoint"
          }
        }
      }
    },
    "playbackEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_s",
        "kind",
        "label",
        "details"
      ],
      "properties": {
        "time_s": {
          "type": "number",
          "minimum": 0
        },
        "kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "details": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}
